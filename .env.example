# =============================================================================
# World Dash — Environment Variables
# Copy this file to .env and edit the values.
# =============================================================================

# ---------- General ----------
ENVIRONMENT=development

# ---------- PostgreSQL ----------
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_DB=worlddash
POSTGRES_USER=worlddash
POSTGRES_PASSWORD=changeme_in_production

# ---------- Redis ----------
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_DB=0

# ---------- Celery ----------
CELERY_BROKER_URL=redis://redis:6379/1
CELERY_RESULT_BACKEND=redis://redis:6379/2

# ---------- API ----------
API_HOST=0.0.0.0
API_PORT=8000
API_WORKERS=4
LOG_LEVEL=INFO

# API authentication (optional — disabled when empty)
# Generate with: python -c "import secrets; print(secrets.token_urlsafe(32))"
API_SECRET_KEY=

# Allowed CORS origins (comma-separated). Default: http://localhost:3000
ALLOWED_ORIGINS=http://localhost:3000

# ---------- Ollama / LLM ----------
OLLAMA_ENDPOINT=http://host.docker.internal:11434
OLLAMA_MODEL=llama3.2
OLLAMA_EMBEDDING_MODEL=nomic-embed-text
OLLAMA_EMBEDDING_DIM=768
OLLAMA_TIMEOUT_SECONDS=60
OLLAMA_ENABLED=true

# ---------- Cloud AI (optional — configure via /settings or API) ----------
# These are stored in Redis at runtime. Env vars are only the initial seed.
# CLOUD_AI_PROVIDER=openai
# CLOUD_AI_API_KEY=sk-...
# CLOUD_AI_MODEL=gpt-4o-mini
# CLOUD_AI_ENDPOINT=

# Encryption key for secrets stored in Redis (cloud AI API key, etc.)
# Generate with: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
ENCRYPTION_KEY=

# ---------- Feed Ingestion ----------
FEED_POLL_INTERVAL_SECONDS=300
MAX_FEED_RETRIES=3
REQUEST_TIMEOUT_SECONDS=30

# ---------- Observability ----------
ENABLE_METRICS=true
ENABLE_TRACING=true

# ---------- Frontend ----------
NEXT_PUBLIC_API_URL=http://localhost:8000
NEXT_PUBLIC_MAPBOX_TOKEN=

