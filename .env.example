# Database
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_DB=worlddash
POSTGRES_USER=worlddash
POSTGRES_PASSWORD=changeme_in_production

# Redis
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_DB=0

# Celery
CELERY_BROKER_URL=redis://redis:6379/1
CELERY_RESULT_BACKEND=redis://redis:6379/2

# API
API_HOST=0.0.0.0
API_PORT=8000
API_WORKERS=4
LOG_LEVEL=INFO

# Frontend
NEXT_PUBLIC_API_URL=http://localhost:8000

# Observability
ENABLE_METRICS=true
ENABLE_TRACING=true

# Ingestion
FEED_POLL_INTERVAL_SECONDS=300
MAX_FEED_RETRIES=3
REQUEST_TIMEOUT_SECONDS=30
